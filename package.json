{
  "name": "ex-cam-ad",
  "version": "0.1.0",
  "private": true,
  "license": "GPL-3.0-only",
  "type": "module",
  "scripts": {
    "serve": "vite --host 0.0.0.0",
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "lint": "eslint --ext .js,.vue \"src/**/*.{js,vue}\"",
    "test:compat": "node --test src/ui/*.test.js src/vue3/*.test.js",
    "test:connections": "node --test src/connections/*.test.js",
    "test:decisions": "node --test src/components/decisions/*.test.js",
    "test:diagrams": "node --test src/bpmn/*.test.js src/components/detail-process-instance/*.test.js",
    "test:reports": "node --test src/config/*.test.js"
  },
  "dependencies": {
    "@bpmn-io/properties-panel": "3.47.0",
    "@fortawesome/fontawesome-svg-core": "^7.3.0",
    "@fortawesome/free-solid-svg-icons": "^7.3.0",
    "@fortawesome/vue-fontawesome": "^3.3.0",
    "axios": "^1.13.0",
    "bootstrap": "^5.3.8",
    "bootstrap-vue-next": "^0.45.7",
    "bpmn-js": "18.19.0",
    "bpmn-js-properties-panel": "5.60.0",
    "bpmn-moddle": "10.0.0",
    "camunda-bpm-sdk-js": "^7.7.4-SNAPSHOT",
    "camunda-bpmn-js-behaviors": "1.18.0",
    "camunda-bpmn-moddle": "7.0.1",
    "camunda-dmn-moddle": "1.3.1",
    "dmn-js": "17.8.1",
    "dmn-moddle": "12.0.1",
    "epic-spinners": "^2.0.0",
    "jquery": "^3.7.1",
    "lodash": "^4.17.21",
    "mkdirp": "^3.0.1",
    "moment": "^2.30.1",
    "string-to-stream": "^3.0.1",
    "vis-network": "^10.1.0",
    "vis-timeline": "^8.5.1",
    "vue": "3.5.39",
    "vue-json-pretty": "^2.6.0",
    "vue-router": "^4.6.4",
    "vuex": "^4.1.0",
    "vuex-persistedstate": "^4.1.0",
    "wrench": "^1.5.9"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/compiler-sfc": "3.5.39",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.33.0",
    "less": "^4.6.7",
    "less-loader": "^13.0.0",
    "sass": "^1.101.0",
    "sass-loader": "^17.0.0",
    "vite": "^8.1.3",
    "vue-eslint-parser": "^9.4.3"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true,
      "browser": true,
      "es2022": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended"
    ],
    "rules": {
      "no-unused-vars": "off",
      "no-empty": "off",
      "no-undef": "off",
      "no-constant-condition": "off",
      "no-redeclare": "off",
      "vue/multi-word-component-names": "off",
      "vue/no-use-v-if-with-v-for": "off",
      "vue/no-v-text-v-html-on-component": "off",
      "vue/require-toggle-inside-transition": "off",
      "vue/no-mutating-props": "off",
      "vue/no-v-model-argument": "off",
      "vue/no-deprecated-slot-attribute": "off",
      "vue/no-deprecated-v-bind-sync": "off"
    },
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 8"
  ]
}
